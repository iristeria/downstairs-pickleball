# ===== 樓下匹克球俱樂部 設定檔 =====
# 複製此檔為 .env 並填入實際值

# 網站網址（部署後的正式網址，結尾不要加 /）
BASE_URL=http://localhost:3000

# 連接埠（多數平台會自動注入 PORT，可不填）
PORT=3000

# 第一位管理員帳號（首次啟動時自動建立，之後修改此處無效）
ADMIN_EMAIL=downstairspickleballclub@gmail.com
ADMIN_PASSWORD=please-change-me-123

# 資料庫檔案位置（部署平台若提供 Volume，指到 Volume 路徑，例如 /data/club.db）
DB_PATH=./data/club.db

# 可預約天數（今天起算）
BOOKING_WINDOW_DAYS=30

# 客服信箱（顯示於登入視窗、預約頁與頁尾）
SERVICE_EMAIL=downstairspickleballclub@gmail.com

# ===== Email 自動寄送（邀請信、忘記密碼信）=====
# 用 Gmail：到 Google 帳戶 → 安全性 → 兩步驟驗證 → 應用程式密碼，
# 產生 16 碼密碼填入 SMTP_PASS（不是您的 Gmail 登入密碼）。
# 留空 = 不寄信，改由管理員在後台複製邀請連結手動傳給會員。
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=downstairspickleballclub@gmail.com
SMTP_PASS=
MAIL_FROM=樓下匹克球俱樂部 <downstairspickleballclub@gmail.com>
# 進階：SMTP_SECURE=0 表示不用 TLS 直連（587 埠 STARTTLS 會自動升級）

# ===== 銀行轉帳資訊（未啟用綠界時顯示給會員）=====
BANK_INFO=銀行：(請填寫)　分行：(請填寫)　戶名：(請填寫)　帳號：(請填寫)

# ===== 綠界 ECPay 金流（選填）=====
# 尚未申請綠界時全部留空 → 網站自動改用「銀行轉帳 + 管理員確認」收款
# 想先測試刷卡流程，可用綠界官方測試商店金鑰：
#   ECPAY_MERCHANT_ID=3002607
#   ECPAY_HASH_KEY=pwFHCqoQZGmho4w6
#   ECPAY_HASH_IV=EkRm7iFT261dpevs
#   ECPAY_STAGE=1
# 正式上線：填入自己商店的三組金鑰，並把 ECPAY_STAGE 改為 0
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_STAGE=1
